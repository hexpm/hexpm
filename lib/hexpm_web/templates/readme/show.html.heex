<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script nonce={@script_src_nonce}>
      (() => {
        const theme = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
    <style nonce={@style_src_nonce}>
      <%= raw(HexpmWeb.ReadmeView.makeup_css()) %>
    </style>
    <style nonce={@style_src_nonce}>
      <%= raw(HexpmWeb.ReadmeView.readme_css()) %>
    </style>
  </head>
  <body>
    <article class="readme">
      {raw(@readme_html)}
    </article>
    <script nonce={@script_src_nonce}>
      document.addEventListener('DOMContentLoaded', function() {
        var origins = <%= raw(Jason.encode!(@parent_origins)) %>;
        function isAllowedOrigin(origin) {
          return origins[0] === "*" || origins.indexOf(origin) >= 0;
        }
        function applyTheme(theme) {
          if (theme !== "light" && theme !== "dark") return;
          document.documentElement.setAttribute("data-theme", theme);
        }
        function sendHeight() {
          var height = document.body.scrollHeight;
          origins.forEach(function(o) {
            window.parent.postMessage({type: 'readme-height', height: height}, o);
          });
        }

        window.addEventListener("message", function(event) {
          if (!event.data || !isAllowedOrigin(event.origin)) return;
          if (event.data.type === "theme-change") {
            applyTheme(event.data.theme);
          }
        });

        sendHeight();
        new ResizeObserver(sendHeight).observe(document.body);
      });
    </script>
  </body>
</html>
