<div class="bg-white dark:bg-grey-800 border border-grey-200 dark:border-grey-700 rounded-lg shadow-sm">
  <div class="px-8 pt-8 pb-4">
    <h1 class="font-bold text-[32px] leading-[36px] text-grey-900 dark:text-white text-center mb-3"><%= assigns[:auth_title] || "Authorize Application" %></h1>
  </div>
  <div class="px-8 pb-8 space-y-4">
    <p class="text-grey-700 dark:text-grey-300">
      <%= assigns[:auth_description] || "The application" %> <strong class="font-semibold text-grey-900 dark:text-white"><%= @client_name %></strong> would like to access your Hex account.
    </p>

    <h3 class="text-lg font-semibold text-grey-900 dark:text-grey-100">Requested permissions</h3>

    <%= form_tag @form_action, method: "post", id: "authorization-form" do %>
      <%= @render_scopes.(@scopes) %>

      <%= for {key, value} <- @hidden_fields do %>
        <input type="hidden" name="<%= key %>" value="<%= value %>">
      <% end %>

      <div class="flex items-center justify-center gap-3 pt-4">
        <%= submit "Authorize", name: "action", value: @approve_value, class: "inline-flex items-center justify-center gap-2 font-semibold rounded h-12 px-4 text-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 dark:focus:ring-offset-grey-800 cursor-pointer bg-primary-600 text-white hover:bg-primary-700 focus:ring-primary-500 flex-1" %>
        <%= submit "Deny", name: "action", value: @deny_value, class: "inline-flex items-center justify-center gap-2 font-semibold rounded h-12 px-4 text-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 dark:focus:ring-offset-grey-800 cursor-pointer bg-white dark:bg-grey-800 border border-red-300 dark:border-red-700 text-red-600 dark:text-red-300 hover:bg-red-50 dark:hover:bg-red-900/30 focus:ring-red-500 whitespace-nowrap" %>
      </div>
    <% end %>
  </div>
</div>

<%= if assigns[:with_checkboxes] do %>
<script nonce="<%= @script_src_nonce %>">
document.addEventListener('DOMContentLoaded', function() {
  var checkboxes = document.querySelectorAll('.scope-checkbox');
  var form = document.getElementById('authorization-form');

  // Validate at least one permission is selected on form submit
  if (form) {
    form.addEventListener('submit', function(e) {
      if (e.submitter && e.submitter.value === '<%= @approve_value %>') {
        var anyChecked = Array.from(checkboxes).some(function(checkbox) {
          return checkbox.checked;
        });

        if (!anyChecked) {
          e.preventDefault();
          alert('Please select at least one permission to authorize.');
        }
      }
    });
  }
});
</script>
<% end %>
