<%!-- Keys section for organization dashboard --%>
<.key_management_card
  keys={@keys}
  organizations={[]}
  packages={[]}
  key_changeset={@key_changeset}
  current_user={@current_user}
  create_key_path={@create_key_path}
  delete_key_path={@delete_key_path}
  generated_key={assigns[:generated_key]}
/>
